# Пример конфигурации GitLab для работы за Traefik
# Скопируйте этот файл в /etc/gitlab/gitlab.rb и настройте под ваши параметры

# Внешний URL (домен через Traefik)
external_url 'http://gitlab.example.com'

# Настройки Nginx для работы за прокси
nginx['listen_port'] = 80
nginx['listen_https'] = false

# Заголовки для прокси
nginx['proxy_set_headers'] = {
  "Host" => "$http_host",
  "X-Real-IP" => "$remote_addr",
  "X-Forwarded-For" => "$proxy_add_x_forwarded_for",
  "X-Forwarded-Proto" => "https",
  "X-Forwarded-Ssl" => "on"
}

# Доверенные прокси (IP адрес Traefik VM)
gitlab_rails['trusted_proxies'] = ['192.168.1.10', '127.0.0.1']

# Отключение встроенного Let's Encrypt (используется Traefik)
letsencrypt['enable'] = false
