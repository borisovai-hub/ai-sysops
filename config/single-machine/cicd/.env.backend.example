# Backend Environment Variables
# РЎРєРѕРїРёСЂСѓР№С‚Рµ СЌС‚РѕС‚ С„Р°Р№Р» РІ /var/www/borisovai-site/backend/.env
# Рё Р·Р°РїРѕР»РЅРёС‚Рµ Р·РЅР°С‡РµРЅРёСЏ

# РћРєСЂСѓР¶РµРЅРёРµ
NODE_ENV=production

# РџРѕСЂС‚ (РїРѕ СѓРјРѕР»С‡Р°РЅРёСЋ 4002, РјРѕР¶РЅРѕ РёР·РјРµРЅРёС‚СЊ)
PORT=4002

# Р‘Р°Р·Р° РґР°РЅРЅС‹С…
DATABASE_URL=postgresql://user:password@localhost:5432/borisovai_db

# JWT Secret (СЃРіРµРЅРµСЂРёСЂСѓР№С‚Рµ Р±РµР·РѕРїР°СЃРЅС‹Р№ РєР»СЋС‡)
JWT_SECRET=your-secret-key-here-change-this

# CORS origins (СЂР°Р·СЂРµС€С‘РЅРЅС‹Рµ РґРѕРјРµРЅС‹ РґР»СЏ CORS)
CORS_ORIGIN=https://borisovai.ru,https://www.borisovai.ru

# Р”РѕРїРѕР»РЅРёС‚РµР»СЊРЅС‹Рµ РїРµСЂРµРјРµРЅРЅС‹Рµ РґР»СЏ РІР°С€РµРіРѕ backend РїСЂРёР»РѕР¶РµРЅРёСЏ
# Р”РѕР±Р°РІСЊС‚Рµ Р·РґРµСЃСЊ СЃРІРѕРё РїРµСЂРµРјРµРЅРЅС‹Рµ РѕРєСЂСѓР¶РµРЅРёСЏ